{
  "schema_version": 1,
  "description": "Search scope boundaries for search-and-verify agents (e.g. Codex). Bounds WHERE to search, not WHEN to stop.",
  "task_families": {
    "lookup": {
      "search_directories": [
        "cli/src/",
        "scripts/",
        "scripts/hooks/",
        "schemas/",
        "docs/"
      ],
      "exclude_from_search": [
        "fixtures/",
        "research/",
        "node_modules/",
        "cli/target/"
      ],
      "verification_shortcuts": [
        {
          "file": "cli/src/main.rs",
          "look_for": "Subcommand",
          "check": "Clap derive structs define all CLI commands and flags"
        },
        {
          "file": "cli/src/agents.rs",
          "look_for": "redact_sensitive_text",
          "check": "Redaction regex patterns; NOT_FOUND enrichment probes detect_gemini_pb_fallback_hint and detect_cursor_vscdb_fallback_hint"
        },
        {
          "file": "cli/src/checkpoint.rs",
          "look_for": "compose_state_message",
          "check": "Checkpoint broadcast entry point; compose_state_message defines git-state message format"
        },
        {
          "file": "scripts/read_session.cjs",
          "look_for": "commandNames",
          "check": "commandNames Set lists every chorus subcommand the Node CLI dispatches"
        }
      ]
    },
    "impact_analysis": {
      "search_directories": [
        "cli/src/",
        "scripts/",
        "schemas/",
        "fixtures/golden/",
        "templates/"
      ],
      "exclude_from_search": [
        "fixtures/session-store/",
        "fixtures/demo/",
        "research/",
        "docs/",
        "node_modules/",
        "cli/target/"
      ],
      "verification_shortcuts": [
        {
          "file": "scripts/conformance.sh",
          "look_for": "run_read_case",
          "check": "expect_success / run_*_case calls list all parity-tested commands"
        },
        {
          "file": "scripts/test_agent_context.sh",
          "look_for": "agent-context",
          "check": "Lists all agent-context integration tests"
        },
        {
          "file": "cli/src/main.rs",
          "look_for": "enum Agent",
          "check": "Agent enum lists all supported agent names; Subcommand derive lists all CLI commands"
        }
      ],
      "derived_file_policy": "Do not list fixtures/golden/*.json individually as change targets. They are regenerated by running conformance tests."
    },
    "planning": {
      "search_directories": [
        "cli/src/",
        "scripts/",
        "schemas/",
        "skills/",
        "templates/"
      ],
      "exclude_from_search": [
        "fixtures/",
        "research/",
        "node_modules/",
        "cli/target/"
      ],
      "verification_shortcuts": [
        {
          "file": "cli/src/agent_context.rs",
          "look_for": "schema_version",
          "check": "Template content functions, init flow, and seal flow with manifest schema-version enforcement"
        }
      ]
    },
    "diagnosis": {
      "search_directories": [
        "cli/src/",
        "scripts/",
        "scripts/adapters/",
        "schemas/"
      ],
      "exclude_from_search": [
        "fixtures/session-store/",
        "fixtures/demo/",
        "research/",
        "node_modules/",
        "cli/target/"
      ],
      "verification_shortcuts": [
        {
          "file": "cli/src/agents.rs",
          "look_for": "redact_sensitive_text",
          "check": "Per-agent JSONL parsing and redaction"
        },
        {
          "file": "scripts/adapters/utils.cjs",
          "look_for": "redactSensitiveText",
          "check": "Node-side redaction patterns"
        },
        {
          "file": "scripts/conformance.sh",
          "look_for": "run_read_case",
          "check": "Parity test definitions"
        }
      ]
    }
  }
}
