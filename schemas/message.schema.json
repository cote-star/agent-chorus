{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-chorus.dev/schemas/message.schema.json",
  "title": "Chorus Agent Message",
  "type": "object",
  "additionalProperties": false,
  "required": ["from", "to", "timestamp", "content", "cwd"],
  "properties": {
    "from": {
      "type": "string",
      "description": "Sending agent identifier"
    },
    "to": {
      "type": "string",
      "description": "Target agent identifier"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the message was sent"
    },
    "content": {
      "type": "string",
      "description": "Message content"
    },
    "cwd": {
      "type": "string",
      "description": "Working directory context"
    }
  }
}
