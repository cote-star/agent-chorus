{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-chorus.dev/schemas/list-output.schema.json",
  "title": "Chorus List Output",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["session_id", "agent", "modified_at", "file_path"],
    "properties": {
      "session_id": {
        "type": "string"
      },
      "agent": {
        "type": "string",
        "enum": ["codex", "gemini", "claude", "cursor"]
      },
      "cwd": {
        "type": ["string", "null"]
      },
      "modified_at": {
        "type": ["string", "null"]
      },
      "file_path": {
        "type": "string"
      },
      "match_snippet": {
        "type": ["string", "null"]
      },
      "scope_hash": {
        "type": "string",
        "description": "For Gemini sessions only: the hex-hash scope directory (SHA-256 of an absolute cwd) when the scope segment is not a human-named directory. Present only when cwd inference fell back to a hex scope; absent otherwise."
      }
    }
  }
}
