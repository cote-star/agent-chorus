{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-chorus.dev/schemas/read-output.schema.json",
  "title": "Chorus Read Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent", "source", "warnings"],
  "properties": {
    "chorus_output_version": {
      "type": "integer",
      "description": "Protocol version for output boundary identification"
    },
    "agent": {
      "type": "string",
      "enum": ["codex", "gemini", "claude", "cursor"]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": ["string", "null"],
      "description": "Session content; null when --metadata-only is used"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "session_id": {
      "type": ["string", "null"]
    },
    "cwd": {
      "type": ["string", "null"]
    },
    "timestamp": {
      "type": ["string", "null"]
    },
    "message_count": {
      "type": "integer",
      "minimum": 0
    },
    "messages_returned": {
      "type": "integer",
      "minimum": 0
    },
    "included_roles": {
      "type": "array",
      "description": "Which roles are included in the output (present when --include-user is used)",
      "items": { "type": "string", "enum": ["user", "assistant"] }
    },
    "included_tool_calls": {
      "type": "boolean",
      "description": "Whether tool call content is included (present when --tool-calls is used)"
    },
    "redactions": {
      "type": "array",
      "description": "Redaction audit trail (present when --audit-redactions is used)",
      "items": {
        "type": "object",
        "required": ["pattern", "count"],
        "properties": {
          "pattern": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
